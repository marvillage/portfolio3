# ── Contact form → online database (Supabase) ───────────────────────────────
# Create a free project at https://supabase.com, then add these.
# The contact API route (app/api/contact/route.ts) inserts submissions into a
# "messages" table. If these are unset, the form still works and falls back to
# opening the user's email client via mailto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Formspree fallback (https://formspree.io) — if set, the API route
# will also forward the message to your email via Formspree.
FORMSPREE_ENDPOINT=
